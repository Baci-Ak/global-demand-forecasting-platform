# ==============================================================================
# bootstrap/tfstate/versions.tf
# ==============================================================================
#
# Purpose
# - Pin Terraform and provider versions for the bootstrap remote state stack.
# ==============================================================================

terraform {
  required_version = ">= 1.6.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.0"
    }
  }
}
