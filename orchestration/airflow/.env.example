# ------------------------------------------------------------------------------
# Airflow Local Environment (Example)
# ------------------------------------------------------------------------------
# Copy this file to `.env` and fill in values.
# Never commit `.env` (it contains secrets).
#
# This file is used by docker-compose to configure Airflow + connections.
# ------------------------------------------------------------------------------

# Airflow UI user (for local dev only)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Airflow core settings
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True

# Use UTC inside Airflow; your project can still be Europe/London in business logic
AIRFLOW__CORE__DEFAULT_TIMEZONE=UTC
